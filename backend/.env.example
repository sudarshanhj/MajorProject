# --- DeepStegAI Environment Template ---
# Copy this file to '.env' and fill in your local values.

# Flask Configuration
FLASK_SECRET_KEY=generate_a_secure_key_here
DEBUG=True

# Database Configuration (PostgreSQL)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/deepstegai

# JWT Configuration
JWT_SECRET_KEY=generate_a_secure_jwt_key

# Admin Configuration
ADMIN_PIN_HASH=place_bcrypt_hash_here

# Email Configuration (SMTP)
# Use a Gmail App Password for SMTP_PASS
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=hjsudarshan18@gmail.com
